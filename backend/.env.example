# サーバー
NODE_ENV=development
PORT=3000

# Claude API
CLAUDE_API_KEY=sk-ant-xxx...

# Google Sheets（いずれか1つ。優先: CREDENTIALS > API_KEY > API_KEY_BASE64）
# サービスアカウント JSON を1行にした文字列
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","client_email":"...@....iam.gserviceaccount.com",...}
# GOOGLE_SHEETS_API_KEY={"type":"service_account",...}
# GOOGLE_SHEETS_API_KEY_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Railway (本番環境のみ自動設定)
# RAILWAY_ENVIRONMENT_NAME=production
